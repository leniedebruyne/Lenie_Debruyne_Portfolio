---
// design.astro
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import "../styles/ux.css";

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio Lenie Debruyne</title>
    <link rel="icon" type="image/svg+xml" href={`${base}images/favicon.svg`} />
    <link rel="
          stylesheet" href="styles.css" />

    <!-- Cormorant Garamond -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Assistant:wght@200..800&family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap"
      rel="stylesheet"
    />

    <!-- Noto Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Assistant:wght@200..800&family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Navigation -->
    <Navigation />

    <div class="content--page">
      <!-- header -->
      <section class="design--header">
        <h1 class="design--header-title">
          <div class="design--header-title-words">
            <span class="visual-word">UX/UI</span>
            <span class="designer-word">DESIGNER</span>
          </div>

          <span class="portfolio-word"
            >PORTFO<span class="green-l">L</span>IO</span
          >
        </h1>
        <div class="design--header-text">
          <p>
            <em>I make user friendly designs that users love and remember.</em>
          </p>
          <p>
            I am a <b>UX/UI designer</b> driven by a passion for creating <b
              >meaningful and intuitive digital experiences</b
            >. I’ve learned to transform creative ideas into <b
              >functional, user-centered products</b
            > that not only work well, but also look <b>visually refined</b>.
          </p>

          <p>
            What motivates me most is <b>interaction with people</b>. Every
            conversation, every bit of feedback offers a <b>new perspective</b>,
            helping me <b>improve designs</b> so they truly meet the needs of real
            users. For me, user experience isn’t just part of the process, <b
              >it is the process</b
            >.
          </p>

          <p>
            I love <b>challenging myself</b> to grow, learning from projects, refining
            my approach, and continuously evolving both <b
              >as a designer and as a person</b
            >.
          </p>
        </div>
        <div class="design--header-cat-wrapper">
          <div class="design--header-cat-bubble">
            <p>Welcome to the <br /> Ux / Ui page.</p>
          </div>
          <img src={`${base}images/cat.png`} alt="cat with text" width="192" />
          <div class="design--header-cat-line"></div>
        </div>
      </section>

      <!-- work carousel -->
      <section class="work--carousel start-left">
        <!-- Card 1: Passion project -->
        <div class="card brandboard">
          <div class="card--image-container">
            <img
              src={`${base}images/teaser-passion.png`}
              alt="passion project"
            />
          </div>
          <div class="card--content">
            <h2>The unseen layer</h2>
            <p>
              The Unseen Layer is an accessible card deck with a Figma plugin
              that helps designers integrate accessibility from the start. It’s
              built on one key idea: design should be not just beautiful, but
              usable and inclusive.
            </p>
            <a
              href="https://www.behance.net/gallery/243647277/The-unseen-layer"
              class="card--button">View more</a
            >
          </div>
        </div>

        <!-- Card 2: Umwelt -->
        <div class="card brandboard">
          <div class="card--image-container">
            <img src={`${base}images/umwelt.png`} alt="Umwelt" />
          </div>
          <div class="card--content">
            <h2>Umwelt</h2>
            <p>
              For this assignment, I explored the concept of umwelt. I chose to
              research crows, and with what I learned, I created a project that
              benefits both humans and crows. Curious how it turned out?
            </p>
            <a href="#umwelt" class="card--button">View more</a>
          </div>
        </div>

        <!-- Card 3: Agency Monkeyshot -->
        <div class="card brandboard">
          <div class="card--image-container">
            <img src={`${base}images/Monkeyshot.png`} alt="Monkeyshot" />
          </div>
          <div class="card--content">
            <h2>Agency Monkeyshot</h2>
            <p>
              I redesigned the digital experience for newcomers in Antwerp,
              based on user research with Atlas. Curious how I turned insights
              into a human-centered solution?
            </p>
            <a href="#monkeyshot" href="#diamond" class="card--button"
              >View more</a
            >
          </div>
        </div>

        <!-- Card 4:Intesellar Starship -->
        <div class="card Moodboard">
          <div class="card--image-container">
            <img src={`${base}images/Starship.png`} alt="Starship" />
          </div>
          <div class="card--content">
            <h2>Intesellar Starship</h2>
            <p>
              I designed a future-focused concept for life aboard a generation
              starship, blending digital and physical elements to support
              well-being. Curious how it turned out?
            </p>
            <a href="#starship" href="#diamond" class="card--button"
              >View more</a
            >
          </div>
        </div>

        <!-- Card 5: / -->
        <div class="card Styleboard">
          <div class="card--image-container">
            <img src={`${base}images/Comming-soon.png`} alt="Styleboard" />
          </div>
          <div class="card--content">
            <h2>comming soon</h2>
            <p>
              This is a project I will be working on in the future. It will
              showcase my passion projects and personal design explorations,
              where I can push the boundaries of creativity and innovation.
            </p>
            <a href="#passion" class="card--button">Stay tuned</a>
          </div>
        </div>
      </section>

      <div class="strip--introduce">
        <div class="strip-inner--introduce">
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>

          <!-- Herhaling -->
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
          <span class="repeat">Let me show you some of my work</span>
        </div>
      </div>

      <h2 class="double_diamond--title">Double diamond</h2>

      <section class="dubble-diamond">
        <div class="dubble-diamond--text">
          <p>
            In our second year of the Experience Design course, we worked with
            the
            <b>Double Diamond framework</b>.
          </p>

          <p>
            Our first assignment was in collaboration with the agency
            Monkeyshot, where we focused on researching how to help immigrants
            feel more at home in Belgium, and explored <b
              >how their social circles influence that experience</b
            >. Fore this assignment we focused on the <b
              >first half of the Double Diamond</b
            >.
          </p>

          <p>
            The second assignment was more focused on the <b
              >second half of the Double Diamond</b
            > (ideation and prototyping), though I <b
              >occasionally reused methods from the discovery phase</b
            >. As you can imagine, these projects involved a <b
              >wide range of UX techniques</b
            >. That's why this page offers a <b
              >concise summary of each project</b
            >.
          </p>

          <p>
            Interested in the full journey? Click "View more" to visit the
            Behance page, where the <b> complete process is documented</b> in detail.
          </p>
        </div>

        <div class="dubble-diamond--projects">
          <div class="projects-grid">
            <div class="moodboard-content" id="monkeyshot">
              <div class="moodboard-texts">
                <h3>Agency <br /> Monkeyshot</h3>
                <p class="hashtag">#Research & Concept</p>
                <div class="moodboard-description">
                  <p>
                    I researched newcomers’ needs in Antwerp and translated
                    insights into design opportunities. This summary highlights
                    the research approach and key outcomes.
                  </p>
                  <p>
                    <a
                      href="https://www.behance.net/gallery/214794167/Immigranten-onderzoeksopdracht"
                      class="mini-card-button"
                      target="_blank"
                      rel="noopener noreferrer">View more</a
                    >
                  </p>
                </div>
              </div>
              <div class="moodboard-image">
                <img src={`${base}images/Monkeyshot.png`} alt="Monkeyshot" />
              </div>
            </div>

            <div class="moodboard-content" id="starship">
              <div class="moodboard-texts">
                <h3>Intesellar <br /> Starship</h3>
                <p class="hashtag">#Concept & Prototype</p>
                <div class="moodboard-description">
                  <p>
                    A future-focused concept for life aboard a generation
                    starship — blending physical and digital solutions to
                    support well-being during long missions.
                  </p>
                  <p>
                    <a
                      href="https://www.behance.net/gallery/225607289/KLM-Watch"
                      class="mini-card-button"
                      target="_blank"
                      rel="noopener noreferrer">View more</a
                    >
                  </p>
                </div>
              </div>
              <div class="moodboard-image">
                <img src={`${base}images/Starship.png`} alt="Starship" />
              </div>
            </div>
          </div>

          <div class="section-accent-dot" aria-hidden="true"></div>
        </div>
      </section>

      <!-- removed duplicate project cards here: grid above replaces these -->

      <h2 class="umwelt--title">Umwelt</h2>

      <section class="dubble-diamond">
        <div class="dubble-diamond--text" id="umwelt">
          <p>
            In my third year of the <b>Experience Design</b> course, I worked with
            the idea of the umwelt.
          </p>

          <p>
            I dived into <b> more-than-human design</b>, also called the <b
              >umwelt</b
            >. It was super interesting to <b>explore</b> this perspective, as it
            pushes you to <b>think beyond</b> what we usually know.
          </p>

          <p>
            For this assignment, I chose to focus on the <b>crow</b>. I
            <b>researched</b> everything I could about them, using a variety of methods
            to really understand their world. With this knowledge, I <b
              >designed</b
            > a more-than-human project that reflects the crow’s perspective.
          </p>

          <p>
            Interested in the full journey? Click "Take a look" to visit the
            Behance page, where the <b>complete process is documented</b> in detail.
          </p>
        </div>

        <div class="dubble-diamond--projects"></div>
      </section>

      <!-- removed duplicate 'Umwelt' card; project is summarized above -->

      <div class="strip--work">
        <div class="strip-inner--work">
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>

          <!-- Herhaling -->
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
          <span class="repeat">Let's work together</span>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <Footer />
  </body>
</html>

<script>
  import { animateProjectPage } from "../scripts/gsap.js";
  animateProjectPage();
</script>
